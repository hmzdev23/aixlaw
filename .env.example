# Gambit — environment variables (copy to .env.local for development)

# --- Engine (T4-T6, owner: Aditya) ---
ANTHROPIC_API_KEY=
# Force the engine to skip Claude calls and use canned fallbacks; useful for tests/CI/demo recovery
GAMBIT_DISABLE_LLM=false
# Optional: override default Anthropic model
GAMBIT_ANTHROPIC_MODEL=claude-sonnet-4-5
# Optional: hide canlii lookup (defaults to allowlist when no CANLII_API_KEY)
GAMBIT_DISABLE_CANLII=false
# CanLII API key (T6 TrueSight verification). When absent, TrueSight uses the offline allowlist.
CANLII_API_KEY=
# Google Cloud Translation API key (T6 Translator + PIA FR consistency pass).
GOOGLE_CLOUD_TRANSLATION_KEY=

# --- Auth & Inbound (T7, owner: Will) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Demo bypass: skip Google OAuth and inject a Sarah persona
GAMBIT_DEMO_MODE=true

# --- Outbound + execution (T8/T9, owner: Will) ---
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
STRIPE_SECRET_KEY=
SPELLBOOK_API_KEY=
