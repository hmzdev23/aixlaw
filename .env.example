# =============================================================================
# Gambit — environment variables
# Copy this file to .env.local and fill in real values. .env.local is gitignored.
# =============================================================================

# --- NextAuth / Google OAuth (T7 — Will) ---------------------------------
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Demo bypass (T7 — Will) ---------------------------------------------
# When "true", a fake Sarah session is injected without Google OAuth.
# Use this on hostile venue Wi-Fi or when running fixtures offline.
GAMBIT_DEMO_MODE=true

# Persona <-> email map. Used to resolve session.user.email -> personaId.
DEMO_EMAIL_SARAH=sarah@dunderai.demo
DEMO_EMAIL_MARC=marc@dunderai.demo
DEMO_EMAIL_INITECH=procurement-legal@initechfg.demo

# --- Slack inbound (T7 — Will) -------------------------------------------
SLACK_SIGNING_SECRET=

# --- Slack outbound (T8 — Will) ------------------------------------------
SLACK_WEBHOOK_URL=

# --- Stripe (T9 — Will) --------------------------------------------------
# Test-mode key only. Currency must be CAD for the Initech demo.
STRIPE_SECRET_KEY=

# --- Spellbook (T9 — Will, optional) -------------------------------------
# If unset, we fall back to fixtures/spellbook_issues.json (T9).
SPELLBOOK_API_KEY=
SPELLBOOK_API_URL=

# --- LLM / engine (Aditya — T4..T6) --------------------------------------
ANTHROPIC_API_KEY=
# Skip Claude and use canned fixtures (tests / hostile Wi‑Fi / CI)
GAMBIT_DISABLE_LLM=false
GAMBIT_ANTHROPIC_MODEL=claude-sonnet-4-5
# Skip live CanLII; use offline allowlist
GAMBIT_DISABLE_CANLII=false

# --- Translation (Aditya — T6) -------------------------------------------
GOOGLE_CLOUD_TRANSLATION_KEY=

# --- CanLII / TrueSight (Aditya — T6) ------------------------------------
CANLII_API_KEY=

# --- Inbound classifier knobs (T7 — Will) --------------------------------
# Polling cadence for the Gmail watcher in seconds. Keep > 5 to respect quota.
GAMBIT_GMAIL_POLL_SECONDS=15
# Max attachments to consider per message.
GAMBIT_GMAIL_MAX_ATTACHMENTS=5
